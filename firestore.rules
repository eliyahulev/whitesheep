rules_version = '2';

// Role-based security rules, tightened to the role matrix (Module 10).
// Roles come from Firebase Auth custom claims and mirror the UI guards.
//   employee: create/update orders, weigh, log items, reserve & return inventory, send messages.
//   manager:  all of the above + audit log, debtors, settings, invoicing, reports.
// Server-side Cloud Functions use the Admin SDK and bypass these rules.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function role() {
      return request.auth.token.role;
    }
    function isManager() {
      return signedIn() && role() == 'manager';
    }
    function isStaff() {
      return signedIn() && (role() == 'manager' || role() == 'employee');
    }

    // Settings: staff read config; only managers edit.
    match /settings/{doc} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    // Audit log: staff append (via logAction); managers read; nobody edits/deletes.
    match /auditLog/{entry} {
      allow read: if isManager();
      allow create: if isStaff();
      allow update, delete: if false;
    }

    // Customers: staff read/create/update; only managers delete.
    match /customers/{id} {
      allow read, create, update: if isStaff();
      allow delete: if isManager();
    }

    // Orders + items: staff create/update (core operational flow); only managers delete.
    match /orders/{id} {
      allow read, create, update: if isStaff();
      allow delete: if isManager();
    }
    match /orderItems/{id} {
      allow read, create, update: if isStaff();
      allow delete: if isManager();
    }

    // Sequential-number counters (order numbering) — staff read/increment.
    match /counters/{id} {
      allow read, write: if isStaff();
    }

    // Inventory + rentals: staff read/write (employees reserve & return).
    match /inventoryItems/{id} {
      allow read, write: if isStaff();
      allow delete: if isManager();
    }
    match /rentals/{id} {
      allow read, create, update: if isStaff();
      allow delete: if isManager();
    }

    // Financial data — payments: managers only (create is done server-side by functions).
    match /payments/{id} {
      allow read, write: if isManager();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
