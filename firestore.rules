rules_version = '2';

// Baseline role-based security rules. Roles come from Firebase Auth custom claims.
// Tightened further in Module 10. Rules mirror the UI guard: employee vs manager.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function role() {
      return request.auth.token.role;
    }
    function isManager() {
      return signedIn() && role() == 'manager';
    }
    function isStaff() {
      return signedIn() && (role() == 'manager' || role() == 'employee');
    }

    // Settings: everyone signed in reads config; only managers edit.
    match /settings/{doc} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    // Audit log: any staff may append (via logAction); nobody edits/deletes.
    // Only managers may read the full log (audit viewer is Module 7, manager-only).
    match /auditLog/{entry} {
      allow read: if isManager();
      allow create: if isStaff();
      allow update, delete: if false;
    }

    // Operational data — customers, orders, order items, inventory, rentals:
    // all staff may read/write (business logic refines this in later modules).
    match /customers/{id}   { allow read, write: if isStaff(); }
    match /orders/{id}      { allow read, write: if isStaff(); }
    match /orderItems/{id}  { allow read, write: if isStaff(); }
    match /inventoryItems/{id} { allow read, write: if isStaff(); }
    match /rentals/{id}     { allow read, write: if isStaff(); }

    // Financial data — payments: staff read; managers write (refined in Module 4/5).
    match /payments/{id} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
