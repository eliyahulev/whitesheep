# Messaging provider config for the sendSms Cloud Function.
# Without credentials the function runs in SIMULATED mode (logs instead of sending),
# so the whole flow is testable locally. Provide these in production.

MESSAGING_PROVIDER=twilio

# Twilio (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
