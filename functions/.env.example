# Messaging provider config for the sendSms Cloud Function.
# Without credentials the function runs in SIMULATED mode (logs instead of sending),
# so the whole flow is testable locally. Provide these in production.

MESSAGING_PROVIDER=twilio

# Twilio (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Morning (Green Invoice) invoicing — SERVER-SIDE only. Absent → simulated mode. ---
# Create a key in Morning: My Account → Developer Tools → API Keys (gives an ID + Secret).
# Sandbox and production are SEPARATE accounts with SEPARATE credentials.
#   MORNING_ENV=sandbox    → https://sandbox.d.greeninvoice.co.il/api/v1
#   MORNING_ENV=production → https://api.greeninvoice.co.il/api/v1
MORNING_ENV=sandbox
MORNING_API_ID=your-morning-api-key-id
MORNING_API_SECRET=your-morning-api-secret
